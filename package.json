    "@stripe/stripe-js": "^9.2.0",
    "@tailwindcss/vite": "^4.1.14",
    "@vis.gl/react-google-maps": "^1.8.3",
    "@vitejs/plugin-react": "^5.0.4",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "dotenv": "^17.2.3",
    "esbuild": "^0.24.0",

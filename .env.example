# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
# Google Maps Platform API Key (Must be prefixed with VITE_ for frontend access)
VITE_GOOGLE_MAPS_PLATFORM_KEY=
# Google Maps Map ID (Required for Advanced Markers)
VITE_GOOGLE_MAPS_MAP_ID=

# Stripe API Keys
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
VITE_STRIPE_PUBLISHABLE_KEY=

# App Configuration
# APP_URL is automatically injected but declared here for documentation.
APP_URL=
VITE_APP_URL=

# Firebase Configuration
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_DATABASE_ID=
# FIREBASE_SERVICE_ACCOUNT: Optional. A JSON string of your Firebase Service Account key.
# Used if the default credentials do not have sufficient permissions.
FIREBASE_SERVICE_ACCOUNT=
# FIREBASE_DATABASE_ID: Optional. The ID of the Firestore database (e.g. "(default)" or a custom ID).
FIREBASE_DATABASE_ID=

# Notification Service Keys
RESEND_API_KEY=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=+61485051625
TWILIO_MESSAGING_SERVICE_SID=
RESEND_FROM_EMAIL=
ADMIN_PHONE_NUMBER=
